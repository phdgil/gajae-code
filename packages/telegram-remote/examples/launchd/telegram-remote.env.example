# macOS launchd wrapper env file.
# Copy to: ~/Library/Application Support/gjc/telegram-remote.env
# Then chmod 600 it. Values are sourced by /bin/sh wrappers, so quote strings
# containing spaces. Do NOT put real tokens in the plist ProgramArguments.

GJC_TELEGRAM_REMOTE_BOT_TOKEN='123456:telegram-bot-token'
GJC_TELEGRAM_REMOTE_ALLOWED_USER_IDS='11111111'
# GJC_TELEGRAM_REMOTE_ALLOWED_CHAT_IDS='-1001234567890'

# Coordinator mode default.
GJC_TELEGRAM_REMOTE_BACKEND='coordinator'
GJC_TELEGRAM_REMOTE_PRESETS='[{"id":"proj","workdir":"/Users/YOU/src/project","sessionCommand":"gjc --worktree","taskTemplate":"Use /skill:ralplan to plan: {{task}}","taskMaxLen":2000}]'
GJC_TELEGRAM_REMOTE_ENABLE_STOP='false'

# RPC mode: socket path must exactly match the launchd RPC session plist --listen path.
# GJC_TELEGRAM_REMOTE_BACKEND='rpc'
# GJC_TELEGRAM_REMOTE_RPC_SOCKET='/Users/YOU/Library/Caches/gjc/telegram-remote.sock'
# GJC_TELEGRAM_REMOTE_STATE_DIR='/Users/YOU/Library/Application Support/gjc/telegram-remote-state'
# GJC_TELEGRAM_REMOTE_LIVENESS_MS='60000'
# GJC_TELEGRAM_REMOTE_ALLOW_ATTACH_SOCKET_ARG='false'

# Optional runtime tuning.
# GJC_TELEGRAM_REMOTE_ENABLE_RICH='true'
# GJC_TELEGRAM_REMOTE_ENABLE_EDIT_MESSAGE_TEXT='false'
# GJC_TELEGRAM_REMOTE_REGISTER_COMMANDS='true'
