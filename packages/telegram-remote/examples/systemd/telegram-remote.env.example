# Telegram Remote service environment file.
# Copy to ~/.config/gjc/telegram-remote.env, fill in real values, then:
#   chmod 600 ~/.config/gjc/telegram-remote.env
#   chmod 700 ~/.config/gjc
# Do NOT commit the copied file. The bot token remains visible to this Unix user
# as process environment; see README for LoadCredential/systemd-creds hardening notes.

GJC_TELEGRAM_REMOTE_BOT_TOKEN=123456:telegram-bot-token
GJC_TELEGRAM_REMOTE_ALLOWED_USER_IDS=11111111
# GJC_TELEGRAM_REMOTE_ALLOWED_CHAT_IDS=-1001234567890

# Default coordinator backend. Set to rpc for the two-unit RPC deployment.
GJC_TELEGRAM_REMOTE_BACKEND=coordinator

# Coordinator mode presets and optional stop support.
GJC_TELEGRAM_REMOTE_PRESETS=[{"id":"proj","workdir":"/home/you/src/project","sessionCommand":"gjc --worktree","taskTemplate":"Use /skill:ralplan to plan: {{task}}","taskMaxLen":2000}]
GJC_TELEGRAM_REMOTE_ENABLE_STOP=false

# RPC mode: these app env values must be concrete paths. systemd %h/%t
# specifiers are not expanded by telegram-remote.
# GJC_TELEGRAM_REMOTE_BACKEND=rpc
# GJC_TELEGRAM_REMOTE_RPC_SOCKET=/run/user/1000/gjc/telegram-remote.sock
# GJC_TELEGRAM_REMOTE_STATE_DIR=/home/you/.local/state/gjc/telegram-remote
# GJC_TELEGRAM_REMOTE_LIVENESS_MS=60000
# GJC_TELEGRAM_REMOTE_ALLOW_ATTACH_SOCKET_ARG=false

# Optional runtime tuning.
# GJC_TELEGRAM_REMOTE_ENABLE_RICH=true
# GJC_TELEGRAM_REMOTE_ENABLE_EDIT_MESSAGE_TEXT=false
# GJC_TELEGRAM_REMOTE_REGISTER_COMMANDS=true
# GJC_TELEGRAM_REMOTE_POLL_TIMEOUT_SEC=30
# GJC_TELEGRAM_REMOTE_API_BASE=https://api.telegram.org

# Optional coordinator overrides.
# GJC_TELEGRAM_REMOTE_COORDINATOR_COMMAND=gjc
# GJC_TELEGRAM_REMOTE_COORDINATOR_ARGS=mcp-serve,coordinator
# GJC_COORDINATOR_MCP_WORKDIR_ROOTS=/home/you/src/project
# GJC_COORDINATOR_MCP_SESSION_COMMAND=gjc --worktree
